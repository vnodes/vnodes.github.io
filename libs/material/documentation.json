            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, computed, input } from '@angular/core';\n\n@Component({\n  selector: 'vn-box',\n  standalone: true,\n  template: `\n    <div\n      class=\"flex flex-col\"\n      [style.height]=\"computedHeight()\"\n      [style.width]=\"computedWidth()\"\n      [title]=\"title()\"\n      [style.aspectRatio]=\"computedRatio()\"\n    >\n      <ng-content>\n        <p> No Content</p>\n      </ng-content>\n    </div>\n  `,\n})\nexport class Box {\n  size = input(0);\n\n  heightRatio = input(1);\n  widthRatio = input(1);\n\n  computedWidth = computed(() => {\n    return this.size() * this.widthRatio() + this.unit();\n  });\n\n  computedHeight = computed(() => {\n    return this.size() * this.heightRatio() + this.unit();\n  });\n\n  computedRatio = computed(() => {\n    return this.heightRatio() + '/' + this.widthRatio();\n  });\n\n  unit = input('px');\n\n  title = computed(() => {\n    return this.computedWidth() + ' X ' + this.computedHeight();\n  });\n}\n",
