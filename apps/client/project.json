{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "vn",
  "sourceRoot": "apps/client/src",
  "i18n": {
    "sourceLocale": "en",
    "locales": {
      "es": {
        "translation": "apps/client/locales/message.es.xlf"
      },
      "fr": {
        "translation": "apps/client/locales/message.fr.xlf"
      },
      "ru": {
        "translation": "apps/client/locales/message.ru.xlf"
      },
      "tr": {
        "translation": "apps/client/locales/message.tr.xlf"
      },
      "za": {
        "translation": "apps/client/locales/message.za.xlf"
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "public/apps/client",
        "browser": "apps/client/src/main.ts",
        "polyfills": [
          "@angular/localize/init"
        ],
        "tsConfig": "apps/client/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/client/public"
          }
        ],
        "styles": [
          "apps/client/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "serviceWorker": "apps/client/ngsw-config.json",
          "localize": true
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "client:build:production"
        },
        "development": {
          "buildTarget": "client:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "client:build",
        "outputPath": "apps/client/locales",
        "outFile": "message.xlf"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "client:build",
        "port": 4200,
        "staticFilePath": "dist/apps/client/browser",
        "spa": true
      }
    }
  }
}